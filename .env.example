# ── WordPress headless source ──────────────────────────────────────────────────
# The URL of the existing WordPress install (no trailing slash).
# REST API endpoints are built from this base automatically.
PUBLIC_WP_URL=https://your-wordpress-domain.com

# ── Vercel / hosting ───────────────────────────────────────────────────────────
# Set this in your Vercel project settings, not here.
# VERCEL_URL is injected automatically by Vercel at build time.

# ── Google reCAPTCHA v2 (checkbox) ─────────────────────────────────────────────
# Protects the ZIP/service-availability check (home page + contact page) from
# spam/bot abuse. Get real keys at https://www.google.com/recaptcha/admin
# Without these set, the site falls back to Google's public TEST keys, which
# always render and always pass verification — fine for local dev, NOT for
# production (anyone can bypass the check).
VITE_RECAPTCHA_SITE_KEY=your-site-key
RECAPTCHA_SECRET_KEY=your-secret-key

# ── Resend (lead email notifications) ──────────────────────────────────────────
# Every website lead form emails the shop's team via Resend. Server-side only —
# the API key is never exposed to the browser. Get a key at
# https://resend.com/api-keys
RESEND_API_KEY=re_your_api_key

# The "From" address. MUST be on a domain you've verified in Resend (Domains →
# add domain → add the DNS records). Display name + address both work.
RESEND_FROM=All Phase Plumbing <leads@allphaseplumbing.com>

# Who receives the leads. Comma-separated. The FIRST address is the primary
# To: recipient; the rest are added as Cc:. Defaults (if unset) to:
# office@allphaseplumbing.com, ReginaW@allphaseplumbing.com,
# larryb@allphaseplumbing.com, gary@allphaseplumbing.com
LEAD_RECIPIENTS=office@allphaseplumbing.com,ReginaW@allphaseplumbing.com,larryb@allphaseplumbing.com,gary@allphaseplumbing.com
